# Login method: "gmail-sso" (default) or "email-password"
NAUKRI_LOGIN_METHOD=gmail-sso

# Google account credentials (required for gmail-sso login)
GOOGLE_EMAIL=your-gmail@gmail.com
GOOGLE_PASSWORD=your-google-password

# Naukri.com direct credentials (only needed if NAUKRI_LOGIN_METHOD=email-password)
NAUKRI_EMAIL=your-email@example.com
NAUKRI_PASSWORD=your-naukri-password

# Browser mode (set to "false" to see the browser window for debugging)
HEADLESS=true

# Email notification settings (Gmail with App Password recommended)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_RECIPIENT=your-email@gmail.com
